{
  "rewrites": [
    { "source": "/admin", "destination": "/admin/index.html" },
    { "source": "/player", "destination": "/player/index.html" },
    { "source": "/screen", "destination": "/screen/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
